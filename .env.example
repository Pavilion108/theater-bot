# =============================================================================
# Theater Automation Bot - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit your .env file to git!
# =============================================================================

# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Optional: Google Places API Key (for better theater search)
# Get one at: https://console.cloud.google.com/apis/credentials
# Leave empty to use free OpenStreetMap/Overpass (slower, less data)
GOOGLE_PLACES_API_KEY=

# Search radius in meters (default: 8000 = 8km)
SEARCH_RADIUS_METERS=8000

# Refresh interval in minutes for monitoring (default: 15)
REFRESH_INTERVAL_MINUTES=15

# Heartbeat interval in minutes (0 = disabled)
HEARTBEAT_INTERVAL_MINUTES=60
